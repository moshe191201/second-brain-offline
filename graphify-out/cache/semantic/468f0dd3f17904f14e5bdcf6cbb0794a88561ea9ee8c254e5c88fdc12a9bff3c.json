{"nodes": [{"id": "raw_a_practical_guide_to_llm_inference_at_scale", "label": "A Practical Guide to LLM Inference at Scale", "file_type": "document", "source_file": "raw/A Practical Guide to LLM Inference at Scale.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/a-practical-guide-to-llm-inference", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_a_practical_guide_to_llm_inference_at_scale_prefill", "label": "Prefill Phase", "file_type": "rationale", "source_file": "raw/A Practical Guide to LLM Inference at Scale.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/a-practical-guide-to-llm-inference", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Processes the whole prompt in one parallel forward pass; compute-bound; measured by Time to First Token (TTFT)"}, {"id": "raw_a_practical_guide_to_llm_inference_at_scale_decoding_phase", "label": "Decoding Phase", "file_type": "rationale", "source_file": "raw/A Practical Guide to LLM Inference at Scale.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/a-practical-guide-to-llm-inference", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Generates one token per step loading model weights and KV cache from HBM; memory-bandwidth bound; measured by Time Per Output Token (TPOT)"}, {"id": "raw_a_practical_guide_to_llm_inference_at_scale_ttft", "label": "Time to First Token (TTFT)", "file_type": "concept", "source_file": "raw/A Practical Guide to LLM Inference at Scale.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/a-practical-guide-to-llm-inference", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_a_practical_guide_to_llm_inference_at_scale_tpot", "label": "Time Per Output Token (TPOT)", "file_type": "concept", "source_file": "raw/A Practical Guide to LLM Inference at Scale.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/a-practical-guide-to-llm-inference", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_a_practical_guide_to_llm_inference_at_scale_static_batching", "label": "Static Batching", "file_type": "rationale", "source_file": "raw/A Practical Guide to LLM Inference at Scale.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/a-practical-guide-to-llm-inference", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Whole batch tied to the longest-running request: finished sequences idle until the longest completes, causing severe GPU underutilization"}, {"id": "raw_a_practical_guide_to_llm_inference_at_scale_continuous_batching", "label": "Continuous Batching", "file_type": "rationale", "source_file": "raw/A Practical Guide to LLM Inference at Scale.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/a-practical-guide-to-llm-inference", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Iteration-level scheduling: finished sequences are evicted and new requests inserted each decoding step; uses ragged batching with attention masks instead of padding"}, {"id": "raw_a_practical_guide_to_llm_inference_at_scale_chunked_prefill", "label": "Chunked Prefill", "file_type": "rationale", "source_file": "raw/A Practical Guide to LLM Inference at Scale.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/a-practical-guide-to-llm-inference", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Splits long prompts into token-budgeted chunks piggybacked alongside decode steps to fix prefill-decode interference, at the cost of higher TTFT and repeated KV cache reloads"}, {"id": "raw_a_practical_guide_to_llm_inference_at_scale_pd_disaggregation", "label": "Prefill-Decode Disaggregation", "file_type": "rationale", "source_file": "raw/A Practical Guide to LLM Inference at Scale.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/a-practical-guide-to-llm-inference", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Runs prefill and decode on separate GPUs so each scales independently; eliminates interference but requires transferring gigabyte-scale KV caches over the network (90+ Gbps or NVLink)"}, {"id": "raw_a_practical_guide_to_llm_inference_at_scale_prefill_decode_interference", "label": "Prefill-Decode Interference", "file_type": "rationale", "source_file": "raw/A Practical Guide to LLM Inference at Scale.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/a-practical-guide-to-llm-inference", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_a_practical_guide_to_llm_inference_at_scale_pagedattention", "label": "PagedAttention", "file_type": "rationale", "source_file": "raw/A Practical Guide to LLM Inference at Scale.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/a-practical-guide-to-llm-inference", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Inspired by OS virtual memory paging: stores the KV cache in non-contiguous fixed-size blocks, cutting memory fragmentation from ~80% to under 4% and enabling much larger batches"}, {"id": "raw_a_practical_guide_to_llm_inference_at_scale_vllm", "label": "vLLM", "file_type": "rationale", "source_file": "raw/A Practical Guide to LLM Inference at Scale.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/a-practical-guide-to-llm-inference", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": 