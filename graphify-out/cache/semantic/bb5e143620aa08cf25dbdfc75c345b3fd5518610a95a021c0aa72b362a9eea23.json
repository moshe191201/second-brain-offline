{"nodes": [{"id": "raw_the_rlhf_landscape_aligning_llms_beyond_sft", "label": "The RLHF Landscape - Aligning LLMs Beyond SFT", "file_type": "document", "source_file": "raw/The RLHF Landscape - Aligning LLMs Beyond SFT.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-rlhf-landscape-aligning-llms", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_the_rlhf_landscape_aligning_llms_beyond_sft_rlhf", "label": "RLHF (Reinforcement Learning from Human Feedback)", "file_type": "rationale", "source_file": "raw/The RLHF Landscape - Aligning LLMs Beyond SFT.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-rlhf-landscape-aligning-llms", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "SFT alone cannot close the gap between technically correct output and output humans prefer; human pairwise judgments are non-differentiable, so policy-gradient RL is needed"}, {"id": "raw_the_rlhf_landscape_aligning_llms_beyond_sft_reinforcement_learning", "label": "Reinforcement Learning", "file_type": "rationale", "source_file": "raw/The RLHF Landscape - Aligning LLMs Beyond SFT.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-rlhf-landscape-aligning-llms", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_the_rlhf_landscape_aligning_llms_beyond_sft_policy", "label": "Policy (RL)", "file_type": "concept", "source_file": "raw/The RLHF Landscape - Aligning LLMs Beyond SFT.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-rlhf-landscape-aligning-llms", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_the_rlhf_landscape_aligning_llms_beyond_sft_reward_model", "label": "Reward Model", "file_type": "rationale", "source_file": "raw/The RLHF Landscape - Aligning LLMs Beyond SFT.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-rlhf-landscape-aligning-llms", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Trained on preference pairs as a scalable proxy for human judgment; its quality caps alignment quality"}, {"id": "raw_the_rlhf_landscape_aligning_llms_beyond_sft_preference_dataset", "label": "Preference Dataset", "file_type": "concept", "source_file": "raw/The RLHF Landscape - Aligning LLMs Beyond SFT.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-rlhf-landscape-aligning-llms", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_the_rlhf_landscape_aligning_llms_beyond_sft_ppo", "label": "PPO (Proximal Policy Optimization)", "file_type": "rationale", "source_file": "raw/The RLHF Landscape - Aligning LLMs Beyond SFT.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-rlhf-landscape-aligning-llms", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Default on-policy RLHF algorithm; clipped surrogate objective bounds policy updates in a trust region; requires four models in memory (actor, critic, reward, reference)"}, {"id": "raw_the_rlhf_landscape_aligning_llms_beyond_sft_reinforce", "label": "REINFORCE", "file_type": "rationale", "source_file": "raw/The RLHF Landscape - Aligning LLMs Beyond SFT.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-rlhf-landscape-aligning-llms", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Simplest policy gradient method; rarely used in production due to high variance of total-episode rewards"}, {"id": "raw_the_rlhf_landscape_aligning_llms_beyond_sft_advantage_function", "label": "Advantage Function", "file_type": "rationale", "source_file": "raw/The RLHF Landscape - Aligning LLMs Beyond SFT.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-rlhf-landscape-aligning-llms", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Measures relative rather than absolute action quality to reduce gradient variance"}, {"id": "raw_the_rlhf_landscape_aligning_llms_beyond_sft_gae", "label": "Generalized Advantage Estimation (GAE)", "file_type": "concept", "source_file": "raw/The RLHF Landscape - Aligning LLMs Beyond SFT.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-rlhf-landscape-aligning-llms", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_the_rlhf_landscape_aligning_llms_beyond_sft_clipped_surrogate", "label": "Clipped Surrogate Objective", "file_type": "rationale", "source_file": "raw/The RLHF Landscape - Aligning LLMs Beyond SFT.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-rlhf-landscape-aligning-llms", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Zeroes gradients when probability ratios exceed epsilon so no batch causes a catastrophic update"}, {"id": "raw_the_rlhf_landscape_aligning_llms_beyond_sft_kl_penalty", "label": "KL Divergence Penalty", "file_type": "rationale", "source_file": "raw/The RLHF Landscape - Aligning LLMs Beyond SFT.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-rlhf-landscape-aligning-llms", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Keeps the policy close to the SFT reference; without it models exploit reward-model quirks producing degenerate high-scoring outputs"}, {"id": "raw_the_rlhf_landscape_aligning_llms_beyond_sft_dpo", "label": "DPO (Direct Preference Optimization)", "file_type": "rationale", "source_file": "raw/The RLHF Landscape - Aligning LLMs Beyond SFT.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-rlhf-landscape-aligning-llms", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Solves the RLHF objective in closed form, reparameterizing reward in terms of the policy: binary cross-entropy over preference pairs, no reward model or RL loop; trades alignment ceiling for cost"}, {"id": "raw_the_rlhf_landscape_aligning_llms_beyond_sft_ipo", "label": "IPO (Identity Preference Optimization)", "file_type": "rationale", "source_file": "raw/The RLHF Landscape - Aligning LLMs Beyond SFT.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-rlhf-landscape-aligning-llms", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "DPO variant with modified loss that is more robust to overfitting"}, {"id": "raw_the_rlhf_landscape_aligning_llms_beyond_sft_kto", "label": "KTO (Kahneman-Tversky Optimization)", "file_type": "rationale", "source_file": "raw/The RLHF Landscape - Aligning LLMs Beyond SFT.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-rlhf-landscape-aligning-llms", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Only needs good/bad labels instead of paired comparisons, easing data collection"}, {"id": "raw_the_rlhf_landscape_aligning_llms_beyond_sft_rejection_sampling", "label": "Rejection Sampling / Best-of-N", "file_type": "concept", "source_file": "raw/The RLHF Landscape - Aligning LLMs Beyond SFT.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-rlhf-landscape-aligning-llms", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_the_rlhf_landscape_aligning_llms_beyond_sft_rlaif", "label": "RLAIF (RL from AI Feedback)", "file_type": "rationale", "source_file": "raw/The RLHF Landscape - Aligning LLMs Beyond SFT.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-rlhf-landscape-aligning-llms", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Replaces human annotators with an AI judge, cutting cost at the risk of inheriting judge biases"}, {"id": "raw_the_rlhf_landscape_aligning_llms_beyond_sft_dpo_paper", "label": "Direct Preference Optimization (Rafailov et al., 2023)", "file_type": "paper", "source_file": "raw/The RLHF Landscape - Aligning LLMs Beyond SFT.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-rlhf-landscape-aligning-llms", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_the_rlhf_landscape_aligning_llms_beyond_sft_ppo_paper", "label": "Proximal Policy Optimization Algorithms (Schulman et al., 2017)", "file_type": "paper", "source_file": "raw/The RLHF Landscape - Aligning LLMs Beyond SFT.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-rlhf-landscape-aligning-llms", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_the_rlhf_landscape_aligning_llms_beyond_sft_instructgpt_paper", "label": "Training language models to follow instructions with human feedback (Ouyang et al., 2022)", "file_type": "paper", "source_file": "raw/The RLHF Landscape - Aligning LLMs Beyond SFT.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-rlhf-landscape-aligning-llms", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}], "edges": [{"source": "raw_the_rlhf_landscape_aligning_llms_beyond_sft", "target": "raw_the_rlhf_landscape_aligning_llms_beyond_sft_rlhf", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "raw/The RLHF Landscape - Aligning LLMs Beyond SFT.md", "source_location": null, "weight": 1.0}, {"source": "raw_the_