{"nodes": [{"id": "raw_understanding_lora_from_first_principles", "label": "Understanding LoRA from First Principles", "file_type": "document", "source_file": "raw/Understanding LoRA from First Principles.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/understanding-lora-from-first-principles", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_understanding_lora_from_first_principles_lora", "label": "LoRA (Low-Rank Adaptation)", "file_type": "rationale", "source_file": "raw/Understanding LoRA from First Principles.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/understanding-lora-from-first-principles", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Freezes W and learns low-rank factors B,A because finetuning updates live in a low-dimensional subspace (intrinsic rank hypothesis); avoids VRAM cost and catastrophic forgetting of full finetuning"}, {"id": "raw_understanding_lora_from_first_principles_intrinsic_rank_hypothesis", "label": "Intrinsic Rank Hypothesis", "file_type": "rationale", "source_file": "raw/Understanding LoRA from First Principles.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/understanding-lora-from-first-principles", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_understanding_lora_from_first_principles_autoencoder", "label": "Autoencoder", "file_type": "rationale", "source_file": "raw/Understanding LoRA from First Principles.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/understanding-lora-from-first-principles", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Demonstrates high-dimensional data compresses into a low-dimensional latent space, the same intuition behind low-rank weight updates"}, {"id": "raw_understanding_lora_from_first_principles_full_finetuning", "label": "Full Finetuning", "file_type": "rationale", "source_file": "raw/Understanding LoRA from First Principles.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/understanding-lora-from-first-principles", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Updates all weights; expensive (gradients + optimizer states) and risks catastrophic forgetting because nothing constrains updates"}, {"id": "raw_understanding_lora_from_first_principles_catastrophic_forgetting", "label": "Catastrophic Forgetting", "file_type": "concept", "source_file": "raw/Understanding LoRA from First Principles.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/understanding-lora-from-first-principles", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_understanding_lora_from_first_principles_peft", "label": "Parameter-Efficient Finetuning (PEFT)", "file_type": "concept", "source_file": "raw/Understanding LoRA from First Principles.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/understanding-lora-from-first-principles", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_understanding_lora_from_first_principles_lora_rank", "label": "LoRA Rank (r)", "file_type": "rationale", "source_file": "raw/Understanding LoRA from First Principles.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/understanding-lora-from-first-principles", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Defines the dimensionality of the update subspace; 8-32 works for most instruction tuning; trade-off is capacity vs efficiency and overfitting"}, {"id": "raw_understanding_lora_from_first_principles_lora_alpha", "label": "LoRA Alpha", "file_type": "rationale", "source_file": "raw/Understanding LoRA from First Principles.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/understanding-lora-from-first-principles", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Scaling alpha/r decouples rank selection from update magnitude; common choice alpha=r or 2r"}, {"id": "raw_understanding_lora_from_first_principles_zero_init_b", "label": "Zero Initialization of B", "file_type": "rationale", "source_file": "raw/Understanding LoRA from First Principles.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/understanding-lora-from-first-principles", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "BA=0 at start so the model initially behaves exactly like the base model, avoiding instability"}, {"id": "raw_understanding_lora_from_first_principles_target_modules", "label": "LoRA Target Modules", "file_type": "rationale", "source_file": "raw/Understanding LoRA from First Principles.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/understanding-lora-from-first-principles", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "q/k/v/o_proj and MLP gate/up/down_proj; targeting all major linear layers approaches full-finetuning quality"}, {"id": "raw_understanding_lora_from_first_principles_unsloth", "label": "Unsloth", "file_type": "code", "source_file": "raw/Understanding LoRA from First Principles.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/understanding-lora-from-first-principles", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_understanding_lora_from_first_principles_hf_peft", "label": "Hugging Face peft Library", "file_type": "code", "source_file": "raw/Understanding LoRA from First Principles.md", "source_location": null, 