{"nodes": [{"id": "raw_the_finetuning_landscape_a_map_of_modern_llm_training", "label": "The Finetuning Landscape - A Map of Modern LLM Training", "file_type": "document", "source_file": "raw/The Finetuning Landscape - A Map of Modern LLM Training.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-finetuning-landscape-a-map-of", "captured_at": "2026-06-09", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_the_finetuning_landscape_a_map_of_modern_llm_training_transformer", "label": "Transformer Architecture", "file_type": "rationale", "source_file": "raw/The Finetuning Landscape - A Map of Modern LLM Training.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-finetuning-landscape-a-map-of", "captured_at": "2026-06-09", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Replaced recurrence because attention can query representations, select information dynamically, and do so in a differentiable, parallelizable way"}, {"id": "raw_the_finetuning_landscape_a_map_of_modern_llm_training_attention_mechanism", "label": "Attention Mechanism", "file_type": "rationale", "source_file": "raw/The Finetuning Landscape - A Map of Modern LLM Training.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-finetuning-landscape-a-map-of", "captured_at": "2026-06-09", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Introduced to let encoder-decoder RNNs look back at all encoder states instead of compressing input into one fixed-length vector"}, {"id": "raw_the_finetuning_landscape_a_map_of_modern_llm_training_self_attention", "label": "Self-Attention", "file_type": "rationale", "source_file": "raw/The Finetuning Landscape - A Map of Modern LLM Training.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-finetuning-landscape-a-map-of", "captured_at": "2026-06-09", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_the_finetuning_landscape_a_map_of_modern_llm_training_positional_encoding", "label": "Sinusoidal Positional Encoding", "file_type": "rationale", "source_file": "raw/The Finetuning Landscape - A Map of Modern LLM Training.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-finetuning-landscape-a-map-of", "captured_at": "2026-06-09", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Injected because attention has no notion of token order; sinusoids at different frequencies encode coarse and fine position"}, {"id": "raw_the_finetuning_landscape_a_map_of_modern_llm_training_multi_head_attention", "label": "Multi-Head Attention", "file_type": "rationale", "source_file": "raw/The Finetuning Landscape - A Map of Modern LLM Training.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-finetuning-landscape-a-map-of", "captured_at": "2026-06-09", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Multiple heads let the model jointly attend to different representation subspaces instead of averaging all relationships into one view"}, {"id": "raw_the_finetuning_landscape_a_map_of_modern_llm_training_scaled_dot_product_attention", "label": "Scaled Dot-Product Attention", "file_type": "rationale", "source_file": "raw/The Finetuning Landscape - A Map of Modern LLM Training.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-finetuning-landscape-a-map-of", "captured_at": "2026-06-09", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_the_finetuning_landscape_a_map_of_modern_llm_training_encoder_only", "label": "Encoder-Only Transformers", "file_type": "rationale", "source_file": "raw/The Finetuning Landscape - A Map of Modern LLM Training.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-finetuning-landscape-a-map-of", "captured_at": "2026-06-09", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Bidirectional attention suits understanding tasks: classification, retrieval, semantic similarity"}, {"id": "raw_the_finetuning_landscape_a_map_of_modern_llm_training_encoder_decoder", "label": "Encoder-Decoder Transformers", "file_type": "rationale", "source_file": "raw/The Finetuning Landscape - A Map of Modern LLM Training.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-finetuning-landscape-a-map-of", "captured_at": "2026-06-09", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Original Transformer design for sequence-to-sequence tasks like translation"}, {"id": "raw_the_finetuning_landscape_a_map_of_modern_llm_training_decoder_only", "label": "Decoder-Only Transformers", "file_type": "rationale", "source_file": "raw/The Finetuning Landscape - A Map of Modern LLM Training.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-finetuning-landscape-a-map-of", "captured_at": "2026-06-09", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Powers modern LLMs: simple next-token objective, massive unlabeled data, efficient parallel training make it ideal for scaling"}, {"id": "raw_the_finetuning_landscape_a_map_of_modern_llm_training_scaling_laws", "label": "Scaling Laws", "file_type": "rationale", "source_file": "raw/The Finetuning Landscape - A Map of Modern LLM Training.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/the-finetuning-landscape-a-map-of", "captured_at": "2026-06-09", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Performance improves as power-law in parameters, data, and compute, so breakthroughs came from scaling rather than new architectures"}, {"id": "raw_the_finetuning_landscape_a_map_of_modern_llm_training_llm_training_pipeline", "label": "LLM Training Pipeline", "file_type": "rationale", "source_file": "raw/The Finetuning Landscape 