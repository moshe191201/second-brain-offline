{"nodes": [{"id": "raw_beyond_text_a_guide_to_vision_tts_finetuning", "label": "Beyond Text: A Guide to Vision & TTS Finetuning", "file_type": "document", "source_file": "raw/Beyond Text A Guide to Vision & TTS Finetuning.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/beyond-text-a-guide-to-vision-and", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_beyond_text_a_guide_to_vision_tts_finetuning_vlm", "label": "Vision-Language Model (VLM)", "file_type": "rationale", "source_file": "raw/Beyond Text A Guide to Vision & TTS Finetuning.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/beyond-text-a-guide-to-vision-and", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Three-stage architecture: vision encoder -> projection layer -> LLM decoder; finetuning freezes the encoder since it already extracts rich features \u2014 only domain-language mapping needs LoRA on the decoder"}, {"id": "raw_beyond_text_a_guide_to_vision_tts_finetuning_vision_encoder", "label": "Vision Encoder", "file_type": "rationale", "source_file": "raw/Beyond Text A Guide to Vision & TTS Finetuning.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/beyond-text-a-guide-to-vision-and", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Almost always a ViT; pretrained on millions of image-text pairs, so it stays frozen during finetuning"}, {"id": "raw_beyond_text_a_guide_to_vision_tts_finetuning_vit", "label": "Vision Transformer (ViT)", "file_type": "concept", "source_file": "raw/Beyond Text A Guide to Vision & TTS Finetuning.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/beyond-text-a-guide-to-vision-and", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_beyond_text_a_guide_to_vision_tts_finetuning_projection_layer", "label": "Projection Layer", "file_type": "rationale", "source_file": "raw/Beyond Text A Guide to Vision & TTS Finetuning.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/beyond-text-a-guide-to-vision-and", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "MLP or cross-attention bridging vision embedding space to the LLM's; may compress 2x2 visual tokens to one because visual tokens are expensive context"}, {"id": "raw_beyond_text_a_guide_to_vision_tts_finetuning_visual_tokens", "label": "Visual Tokens", "file_type": "concept", "source_file": "raw/Beyond Text A Guide to Vision & TTS Finetuning.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/beyond-text-a-guide-to-vision-and", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_beyond_text_a_guide_to_vision_tts_finetuning_tts_finetuning", "label": "LLM-based TTS", "file_type": "rationale", "source_file": "raw/Beyond Text A Guide to Vision & TTS Finetuning.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/beyond-text-a-guide-to-vision-and", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Treats audio as just another language: the LLM predicts next audio token instead of text token, replacing the multi-stage text-normalization/phoneme/prosody/vocoder pipeline"}, {"id": "raw_beyond_text_a_guide_to_vision_tts_finetuning_neural_audio_codec", "label": "Neural Audio Codec", "file_type": "rationale", "source_file": "raw/Beyond Text A Guide to Vision & TTS Finetuning.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/beyond-text-a-guide-to-vision-and", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Tokenizer for sound: encodes waveforms into discrete codebook codes and decodes them back (lossy); the key innovation enabling LLM-based TTS"}, {"id": "raw_beyond_text_a_guide_to_vision_tts_finetuning_snac", "label": "SNAC Codec", "file_type": "rationale", "source_file": "raw/Beyond Text A Guide to Vision & TTS Finetuning.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/beyond-text-a-guide-to-vision-and", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Multi-scale codec at 24kHz with 3 hierarchical layers (12/24/48 Hz) interleaved into 7 tokens per frame, ~83 tokens/second, 4096-entry codebooks"}, {"id": "raw_beyond_text_a_guide_to_vision_tts_finetuning_orpheus", "label": "Orpheus-TTS", "file_type": "rationale", "source_file": "raw/Beyond Text A Guide to Vision & TTS Finetuning.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/beyond-text-a-guide-to-vision-and", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Canopy Labs TTS on a Llama 3B backbone predicting SNAC audio tokens; emotive tags, 8 preset voices, ~200ms streaming latency; small models preferred because TTS prioritizes latency"}, {"id": "raw_beyond_text_a_guide_to_vision_tts_finetuning_qwen3_vl", "label": "Qwen3-VL", "file_type": "rationale", "source_file": "raw/Beyond Text A Guide to Vision & TTS Finetuning.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/beyond-text-a-guide-to-vision-and", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "256K native context, DeepStack multi-level ViT feature fusion, Interleaved-MRoPE, text-timestamp alignment for video, 32-language OCR, toggleable thinking mode"}, {"id": "raw_beyond_text_a_guide_to_vision_tts_finetuning_voice_cloning", "label": "Voice Cloning via Finetuning", "file_type": "rationale", "source_file": "raw/Beyond Text A Guide to Vision & TTS Finetuning.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/beyond-text-a-guide-to-vision-and", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Finetuning on ~30 minutes of clean single-speaker audio captures pacing and quirks that zero-shot cloning misses"}, {"id": "raw_beyond_text_a_guide_to_vision_tts_finetuning_vocabulary_extension", "label": "Audio Vocabulary Extension", "file_type": "rationale", "source_file": "raw/Beyond Text A Guide to Vision & TTS Finetuning.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/beyond-text-a-guide-to-vision-and", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null, "rationale": "Audio token IDs are offset past the text vocabulary so the LLM can predict them with standard next-token prediction"}, {"id": "raw_beyond_text_a_guide_to_vision_tts_finetuning_snac_paper", "label": "SNAC Codec Paper (arXiv 2410.14411)", "file_type": "paper", "source_file": "raw/Beyond Text A Guide to Vision & TTS Finetuning.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/beyond-text-a-guide-to-vision-and", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_beyond_text_a_guide_to_vision_tts_finetuning_qwen3_vl_report", "label": "Qwen3-VL Technical Report (arXiv 2511.21631)", "file_type": "paper", "source_file": "raw/Beyond Text A Guide to Vision & TTS Finetuning.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/beyond-text-a-guide-to-vision-and", "captured_at": "2026-06-10", "author": "Miguel Otero Pedrido", "contributor": null}, {"id": "raw_beyond_text_a_guide_to_vision_tts_finetuning_llama_3b", "label": "Llama 3B Backbone", "file_type": "concept", "source_file": "raw/Beyond Text A Guide to Vision & TTS Finetuning.md", "source_location": null, "source_url": "https://theneuralmaze.substack.com/p/beyond-text-a-guide-to-vision-and", "captured_at": "